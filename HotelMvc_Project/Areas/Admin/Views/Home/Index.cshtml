@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="mb-3">Admin Dashboard</h2>
            <p class="text-muted">Welcome to the administration area.</p>

            <div class="list-group mt-4">

                <a asp-area="Admin"
                       asp-controller="Hotels"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                    🏨 Manage Hotels
                </a>

                <a asp-area=""
                       asp-controller="Hotels"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                    🌍 View Public Hotels
                </a>

                <a asp-area=""
                       asp-controller="Rooms"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                    🛏️ View Public Rooms
                </a>

                <a asp-area=""
                       asp-controller="Reservations"
                       asp-action="My"
                       class="list-group-item list-group-item-action">
                    📅 My Reservations
                </a>

                <a asp-area="Admin"
                       asp-controller="Rooms"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                    🛏️ Manage Rooms
                </a>

                <a asp-area="Admin"
                       asp-controller="Guests"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                    👥 Manage Guests
                </a>

                <a asp-area="Admin"
                       asp-controller="Reservations"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                    📅 Manage Reservations
                </a>

            </div>
        </div>
    </div>
</div>