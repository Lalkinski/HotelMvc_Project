@using HotelMvc.Core.Models.Reservation
@model ReservationDetailsServiceModel

@{
    ViewData["Title"] = "Reservation Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="card-title">Reservation Details</h2>

            <p class="card-text">
                <strong>Hotel:</strong> @Model.HotelName
            </p>

            <p class="card-text">
                <strong>Room Type:</strong> @Model.RoomType
            </p>

            <p class="card-text">
                <strong>Check-in:</strong> @Model.CheckInDate.ToString("dd.MM.yyyy")
            </p>

            <p class="card-text">
                <strong>Check-out:</strong> @Model.CheckOutDate.ToString("dd.MM.yyyy")
            </p>

            <p class="card-text">
                <strong>Guests Count:</strong> @Model.GuestsCount
            </p>

            <p class="card-text">
                <strong>Total Price:</strong> @Model.TotalPrice.ToString("F2") BGN
            </p>

            <p class="card-text">
                <strong>Status:</strong>
                @if (Model.Status == "Confirmed")
                {
                    <span class="badge bg-success">@Model.Status</span>
                }
                else if (Model.Status == "Pending")
                {
                    <span class="badge bg-warning text-dark">@Model.Status</span>
                }
                else
                {
                    <span class="badge bg-secondary">@Model.Status</span>
                }
            </p>

            <a asp-controller="Reservations" asp-action="My" class="btn btn-secondary">
                Back to My Reservations
            </a>
        </div>
    </div>
</div>