@using HotelMvc.Core.Models.Reservation
@model ReservationFormModel

@{
    ViewData["Title"] = "Create Reservation";
}

<div class="container mt-4">
    <h2 class="mb-4">Create Reservation</h2>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="RoomId" type="hidden" />

        <div class="mb-3">
            <label asp-for="CheckInDate" class="form-label"></label>
            <input asp-for="CheckInDate" class="form-control" />
            <span asp-validation-for="CheckInDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CheckOutDate" class="form-label"></label>
            <input asp-for="CheckOutDate" class="form-control" />
            <span asp-validation-for="CheckOutDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="GuestsCount" class="form-label"></label>
            <input asp-for="GuestsCount" class="form-control" />
            <span asp-validation-for="GuestsCount" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Reserve</button>
        <a asp-controller="Rooms" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}